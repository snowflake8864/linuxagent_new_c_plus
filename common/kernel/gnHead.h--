// open file information to user
typedef enum {
    ACTION_WRITE_FILE = 0 ,
    ACTION_RENAME,
    ACTION_BOOT,
    ACTION_LOADLIB,
    ACTION_INOTIFY = 0,
} FILE_AUDIT_ACTION;

typedef struct {
    pid_t pid;
    FILE_AUDIT_ACTION action;
    char filepath[1024];
} KFILE_INFO;

struct av_process_info {
    int pid;
    int ppid;
    int uid;
    void* pwait_flag;
    char comm[16];
    char comm_p[16];
    //char dst_path[1024];
    int type;
    int is_dir:3,
        deny:3,
        param_pos:10,
        is_monitor_mode:2;
    char path[1024];
    //char param[1024];
};

struct av_file_info {
    int pid;
    int ppid;
    int uid;
    void* pwait_flag;
    char comm[512];
    char comm_p[16];
    char path[1024];
    char dst_path[1024];
    uint16_t type;
    uint32_t is_dir:3,
        deny:3,
        is_monitor_mode:2,
        rules_type:4,
        rules_idx:8,
        protect_rw:6,
		is_file:1;
};

struct av_self_protection_info {
    int pid;
    int ppid;
    int uid;
    int type;
    char comm[512];
    char comm_p[16];
    char path[1024];
    char dst_path[1024];
};

