#define KTQ_DATA_MAX 8192
#define KTQ_IOC_MAGIC ('T' + 'Q')
#define KTQ_IOC_SETVAL (_IOW(KTQ_IOC_MAGIC, 0x1,kosecs_data_t))

#define KTQ_SET_DATA(data,_type,_len,_paddr) \
                    data.type = _type;      \
                    data.len = _len;         \
                    data.addr = _paddr;


