//charater device
typedef struct {
    uint16_t type;//对应前面user向kernel发送的NL_POLICY_XXX
    uint16_t len;//data的长度
    void* addr; //用户空间地址
}kosecs_data_t;

//内核发给用户态的数据格式
struct kosecs_msg_data {
    int data_type;//对应前面kernel向user发送的NL_POLICY_XXX_NOTIFY
    int data_len;
    char data[0];
};

